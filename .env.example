# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-char-random-secret-here

# Database — Neon Postgres (https://neon.tech)
# Use the "pooled" connection string for DATABASE_URL
# Use the "direct" connection string for DATABASE_DIRECT_URL
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DATABASE_DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Stripe — https://dashboard.stripe.com/apikeys
# Live keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Test keys
STRIPE_TEST_KEY=sk_test_...
STRIPE_WEBHOOK_TEST=whsec_...

# Override which keys to use — set to "test" or "live"
# Locally defaults to "test", on Vercel defaults to "live"
# Add STRIPE_MODE=test in Vercel env vars to force test mode in production
STRIPE_MODE=test

# Email — https://resend.com (free tier: 100/day)
RESEND_API_KEY=re_...

# Your email — receives "Message the Owner" submissions
OWNER_EMAIL=you@youremail.com

# Set to "true" to unlock the Directory for members (default: locked with countdown)
DIRECTORY_UNLOCKED=false
