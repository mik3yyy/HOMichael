# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-char-random-secret-here

# Database (SQLite for dev, swap to Postgres url for prod)
DATABASE_URL="file:./dev.db"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email — https://resend.com (free tier: 100/day)
RESEND_API_KEY=re_...

# Your email — receives "Message the Owner" submissions
OWNER_EMAIL=you@youremail.com
