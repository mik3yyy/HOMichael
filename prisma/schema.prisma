generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

model Member {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  firstName       String
  tier            String   // "MICHAEL" | "INSPIRED"
  tierLevel       String   @default("MEMBER") // "MEMBER"|"MIKE"|"MJ"|"GOAT"
  stripeSessionId String?
  joinedAt        DateTime @default(now())

  // Profile
  city            String?
  country         String?
  industry        String?
  bio             String?
  building        String?
  canHelpWith     String?  // comma-separated
  lookingFor      String?  // comma-separated
  avatarUrl       String?
  linkedinUrl     String?
  profileComplete Boolean  @default(false)

  // Referral
  referralCode    String   @unique
  referredByCode  String?

  // Relations
  podId     String?
  pod       Pod?           @relation(fields: [podId], references: [id])
  checkIns  CheckIn[]
  posts     Post[]
  responses PostResponse[]
  votes     FeatureVote[]
  feedbacks Feedback[]
}

model Pod {
  id        String   @id @default(cuid())
  cohort    Int
  createdAt DateTime @default(now())

  members  Member[]
  checkIns CheckIn[]
}

model CheckIn {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  podId     String
  pod       Pod      @relation(fields: [podId], references: [id])
  week      String   // "2026-W22"
  lastWeek  String?
  thisWeek  String?
  blocker   String?
  createdAt DateTime @default(now())

  @@unique([memberId, week])
}

model Post {
  id        String         @id @default(cuid())
  type      String         // "HELPME" | "COLLAB"
  category  String
  title     String
  body      String
  tags      String         @default("[]")
  authorId  String
  author    Member         @relation(fields: [authorId], references: [id])
  responses PostResponse[]
  createdAt DateTime       @default(now())
}

model PostResponse {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  message   String?
  createdAt DateTime @default(now())

  @@unique([postId, memberId])
}

model FeatureVote {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  feature   String
  createdAt DateTime @default(now())

  @@unique([memberId, feature])
}

model Feedback {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  mustHave  String?
  referral  String?
  missing   String?
  createdAt DateTime @default(now())
}

model PageEvent {
  id        String   @id @default(cuid())
  event     String   // "page_view" | "step_1"..."step_8" | "signin_click" | "signin_attempt"
  step      Int?
  sessionId String?
  source    String?  // utm_source or referrer domain
  refCode   String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}
